# Production environment for the VPS stack. Copy to deploy/vps/.env (gitignored) and fill in.
# Consumed twice: docker compose interpolates ${...} here, and the eden service loads it wholesale.

# ── Postgres ────────────────────────────────────────────────────────────────────────────────
# Password for the stack's postgres container (user/db are both "eden").
EDEN_PG_PASSWORD=
# Eden runs with host networking, so it reaches Postgres on the host loopback port.
# Write the SAME password here in full — env-file values are literal (no ${...} expansion).
DATABASE_URL=postgres://eden:CHANGE-ME@localhost:5442/eden

# ── Core ────────────────────────────────────────────────────────────────────────────────────
EDEN_MODE=oss
EDEN_DEPLOY_TARGET=local-docker
# Local secrets encryption key (AES-256-GCM). Generate with: openssl rand -hex 32
# Losing this key means re-entering every stored secret — back it up.
EDEN_SECRETS_KEY=

# ── Better Auth (email/password auth + organization tenancy) ─────────────────────────────────
# Generate at least 32 bytes of high-entropy secret material and keep it backed up:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Eden's public same-origin URL (no trailing slash).
BETTER_AUTH_URL=https://eden.example.com

# Optional marketing host (bare host, no scheme). When set, the editorial landing page and
# /case-studies serve ONLY on this host, and `/` on the BETTER_AUTH_URL host is Front of House.
# Requires a DNS record, the marketing server blocks in nginx-eden.conf, and certificate
# coverage for the host (README step 6). Self-host default: leave unset — `/` serves Front of
# House and no marketing host is needed.
#MARKETING_HOST=www.eden.example.com

# Postmark delivers password resets and workspace invitations in production.
POSTMARK_SERVER_TOKEN=
# Must be a verified Postmark sender or sender signature.
FROM_EMAIL=Eden <noreply@eden.example.com>

# ── GitHub App (Connect pillar) ─────────────────────────────────────────────────────────────
# The App's Webhook URL must be https://<your-domain>/api/github/webhook and its Setup URL
# https://<your-domain>/connect (see README step 7).
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM as ONE line with \n escapes (compose env-file parsing rejects real multiline values):
#   awk 'NF {printf "%s\\n", $0}' your-app.private-key.pem
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Discord app (optional — one-click Discord channel, issue #32) ────────────────────────────
# Register ONE Discord app for this installation and add https://<domain>/discord/callback to
# its OAuth2 Redirects. The Interactions Endpoint URL is set automatically at connect time.
# The bot token stays on the control plane and is never shipped to agent instances.
#EDEN_DISCORD_APPLICATION_ID=
#EDEN_DISCORD_BOT_TOKEN=
#EDEN_DISCORD_PUBLIC_KEY=

# ── Authoring assistant ─────────────────────────────────────────────────────────────────────
EDEN_ASSISTANT=claude
ANTHROPIC_API_KEY=

# ── Deployed agents ─────────────────────────────────────────────────────────────────────────
# Port eve listens on INSIDE each agent container (host ports are assigned dynamically).
EDEN_INSTANCE_PORT=3000
# Teammate delegation relay URL as seen FROM INSIDE an agent container. Defaults to
# http://host.docker.internal:$PORT — set this if your Eden container isn't reachable there.
#EDEN_TEAM_RELAY_URL=
# Public origin of this Eden control plane (e.g. https://eden.example.com). When set, every
# deployed instance receives EVE_PUBLIC_ORIGIN=<origin>/e/<environmentId> — its public ingress
# URL — so channels/connections that take inbound webhooks can build callback URLs.
#EDEN_PUBLIC_ORIGIN=
