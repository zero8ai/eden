# Copy to .env.local and fill in. .env.local is gitignored.

# Control-plane Postgres (D7: same engine backs the Workflow World).
DATABASE_URL=postgres://eden:eden@localhost:5442/eden

# Runtime mode: 'oss' (default, local/BYO impls) or 'managed' (KMS/gateway/Stripe).
EDEN_MODE=oss

# Local secrets encryption key (AES-256-GCM). 32 bytes as 64 hex chars.
# Generate with: openssl rand -hex 32
EDEN_SECRETS_KEY=

# WorkOS AuthKit — populated by `npx workos@latest install` (D2).
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# WORKOS_COOKIE_PASSWORD=
# WORKOS_REDIRECT_URI=http://localhost:5173/callback

# GitHub App (Connect pillar). Register an App with repo Contents R/W, Pull requests,
# and set its Setup URL to http://localhost:5173/connect. Then fill these in.
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=eden-your-app        # from the App's public URL github.com/apps/<slug>
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_PRIVATE_KEY=              # PEM; single line with \n escapes, or a real multiline value
# GITHUB_WEBHOOK_SECRET=               # optional until we wire webhooks (M1)

# Authoring assistant (Author pillar). Default generator is Claude (needs a key).
ANTHROPIC_API_KEY=
EDEN_ASSISTANT=claude

# Deploy target: container | local-docker | nomad | vercel
EDEN_DEPLOY_TARGET=local-docker
EDEN_INSTANCE_PORT=3000

# Background job worker (builds/deploys run here, not in request handlers)
# EDEN_WORKER_POLL_MS=2000
# EDEN_DISABLE_WORKER=1               # e.g. in one-off scripts/tests
