# Copy to .env.local and fill in. .env.local is gitignored.

# Control-plane Postgres (D7: same engine backs the Workflow World).
DATABASE_URL=postgres://eden:eden@localhost:5432/eden

# WorkOS AuthKit — populated by `npx workos@latest install` (D2).
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# WORKOS_COOKIE_PASSWORD=
# WORKOS_REDIRECT_URI=http://localhost:5173/callback
