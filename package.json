{
  "name": "eden",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:tunnel": "node scripts/dev-tunnel.mjs",
    "tunnel:init": "node scripts/tunnel-init.mjs",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "db:generate": "drizzle-kit generate",
    "auth:generate": "npx --yes auth@1.6.23 generate --config ./app/lib/auth.server.ts --output ./app/db/auth-schema.ts --yes",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "catalog:validate": "node catalog/scripts/validate.mjs",
    "catalog:index": "node catalog/scripts/build-index.mjs",
    "doctor": "npx react-doctor@latest",
    "email:dev": "email dev --dir app/email/templates --port 8092"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@fontsource-variable/geist": "^5.2.9",
    "@react-email/components": "^1.0.12",
    "@react-router/node": "^8.1.0",
    "@react-router/serve": "8.0.0",
    "@uiw/react-codemirror": "^4.25.10",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5",
    "lucide-react": "^1.23.0",
    "nanoid": "^5.1.16",
    "nodemailer": "^9.0.3",
    "octokit": "^5.0.5",
    "postgres": "^3.4.9",
    "postmark": "^5.0.0",
    "prettier": "^3.9.4",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.0.0",
    "semver": "^7.8.5",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@react-router/dev": "8.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "drizzle-kit": "^0.31.10",
    "react-doctor": "^0.6.0",
    "react-email": "^6.6.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.9"
  }
}
